# =============================================================================
# Single source of config — copy to .env and fill in values
# Used by: backend, docker-compose
# =============================================================================

# ---- App ----
PORT=9002

# ---- MySQL ----
DB_HOST=localhost          # use 'mysql' when running inside Docker
DB_PORT=3306
DB_USER=root
DB_PASS=password
DB_NAME=myapp

# ---- Redis ----
REDIS_HOST=localhost       # use 'redis' when running inside Docker
REDIS_PORT=6379

# ---- Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---- k6 (load test) ----
K6_BASE_URL=http://localhost:9002
K6_PROMETHEUS_RW_SERVER_URL=http://localhost:9090/api/v1/write
